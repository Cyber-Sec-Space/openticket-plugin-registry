[
  {
    "id": "github-issues",
    "name": "GitHub Issues Integration",
    "description": "Automatically creates a GitHub issue when a new security incident is reported.",
    "author": "OpenTicket Team",
    "icon": "github",
    "latestVersion": "1.0.0",
    "versions": {
      "1.0.0": {
        "sourceType": "registry",
        "configSchema": [
          {
            "key": "GITHUB_TOKEN",
            "type": "string",
            "label": "GitHub Personal Access Token",
            "required": true
          },
          {
            "key": "GITHUB_OWNER",
            "type": "string",
            "label": "Repository Owner (User or Org)",
            "required": true
          },
          {
            "key": "GITHUB_REPO",
            "type": "string",
            "label": "Repository Name",
            "required": true
          },
          {
            "key": "ISSUE_LABELS",
            "type": "string",
            "label": "Issue Labels (comma separated)",
            "required": false
          }
        ]
      }
    }
  }
]
