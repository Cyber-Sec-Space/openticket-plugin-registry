{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenTicket Hybrid Plugin Registry Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "author": {
        "type": "string"
      },
      "icon": {
        "type": "string"
      },
      "latestVersion": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "versions": {
        "type": "object",
        "patternProperties": {
          "^\\d+\\.\\d+\\.\\d+$": {
            "type": "object",
            "properties": {
              "sourceType": {
                "type": "string",
                "enum": ["npm", "registry"]
              },
              "packageName": {
                "type": "string"
              },
              "configSchema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "key": { "type": "string" },
                    "type": { "type": "string", "enum": ["string", "number", "boolean"] },
                    "label": { "type": "string" },
                    "required": { "type": "boolean" }
                  },
                  "required": ["key", "type", "label", "required"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["sourceType", "configSchema"],
            "allOf": [
              {
                "if": { "properties": { "sourceType": { "const": "npm" } } },
                "then": { "required": ["packageName"] }
              }
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "required": [
      "id",
      "name",
      "description",
      "author",
      "icon",
      "latestVersion",
      "versions"
    ],
    "additionalProperties": false
  }
}
