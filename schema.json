{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenTicket Plugin Registry Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "name": {
        "type": "string"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "description": {
        "type": "string"
      },
      "author": {
        "type": "string"
      },
      "icon": {
        "type": "string"
      },
      "configSchema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "key": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": ["string", "number", "boolean"]
            },
            "label": {
              "type": "string"
            },
            "required": {
              "type": "boolean"
            }
          },
          "required": [
            "key",
            "type",
            "label",
            "required"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "id",
      "name",
      "version",
      "description",
      "author",
      "icon",
      "configSchema"
    ],
    "additionalProperties": false
  }
}
