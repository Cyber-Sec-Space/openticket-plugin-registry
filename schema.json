{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenTicket Hybrid Plugin Registry Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "author": {
        "type": "string"
      },
      "developer": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "website": { "type": "string" }
        },
        "required": ["name", "email"]
      },
      "repositoryUrl": {
        "type": "string",
        "format": "uri"
      },
      "icon": {
        "type": "string"
      },
      "latestVersion": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$"
      },
      "versions": {
        "type": "object",
        "patternProperties": {
          "^\\d+\\.\\d+\\.\\d+$": {
            "type": "object",
            "properties": {
              "sourceType": {
                "type": "string",
                "enum": ["npm", "registry"]
              },
              "packageName": {
                "type": "string"
              },
              "integritySha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              },
              "requestedPermissions": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 0
              },
              "supportedPluginApiVersion": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "configSchema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "key": { "type": "string" },
                    "type": { "type": "string", "enum": ["string", "number", "boolean", "secret"] },
                    "label": { "type": "string" },
                    "required": { "type": "boolean" },
                    "options": {
                      "type": "array",
                      "items": { "type": "string" },
                      "minItems": 1
                    },
                    "dependsOn": {
                      "type": "object",
                      "properties": {
                        "key": { "type": "string" },
                        "value": { "type": "string" }
                      },
                      "required": ["key", "value"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["key", "type", "label", "required"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["sourceType", "configSchema", "requestedPermissions"],
            "allOf": [
              {
                "if": { "properties": { "sourceType": { "const": "npm" } } },
                "then": { "required": ["packageName"] }
              },
              {
                "if": { "properties": { "sourceType": { "const": "registry" } } },
                "then": { "required": ["integritySha256"] }
              }
            ],
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "required": [
      "id",
      "name",
      "description",
      "author",
      "developer",
      "icon",
      "latestVersion",
      "versions"
    ],
    "additionalProperties": false
  }
}
